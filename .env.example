# Unraid server URL (e.g. https://192.168.1.100 or https://tower.local)
UNRAID_API_URL=https://tower.local

# Unraid API key — generate in Unraid UI: Settings > Management Access > API Keys
UNRAID_API_KEY=your_api_key_here

# Whether to verify SSL certificates (true/false, or path to CA bundle)
UNRAID_VERIFY_SSL=false

# Bearer token that MCP clients must present to this server
BRAINLESS_MCP_BEARER_TOKEN=change_me_to_a_strong_secret

# Transport: stdio | http | sse | streamable-http
BRAINLESS_MCP_TRANSPORT=stdio

# HTTP server port (used when transport is http/sse/streamable-http)
BRAINLESS_MCP_PORT=8000

# Logging
BRAINLESS_MCP_LOG_LEVEL=INFO
BRAINLESS_MCP_LOG_FILE=

# Auto-start WebSocket subscriptions on startup
UNRAID_AUTO_START_SUBSCRIPTIONS=false

# Max reconnect attempts for WebSocket subscriptions
UNRAID_MAX_RECONNECT_ATTEMPTS=10
